{
    "name": "@100monkeys-ai/smcp",
    "version": "0.14.0-pre-alpha",
    "type": "module",
    "description": "TypeScript client wrapper for the Secure Model Context Protocol (SMCP)",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "scripts": {
        "build": "tsc",
        "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js",
        "lint": "eslint src/**/*.ts",
        "prepare": "npm run build"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/100monkeys-ai/secure-model-context-protocol.git"
    },
    "keywords": [
        "smcp",
        "mcp",
        "security",
        "ai",
        "agents"
    ],
    "author": "100monkeys.ai",
    "license": "MIT",
    "publishConfig": {
        "registry": "https://npm.pkg.github.com"
    },
    "dependencies": {
        "@noble/ed25519": "^2.1.0"
    },
    "overrides": {
        "brace-expansion": ">=5.0.5"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/jest": "^30.0.0",
        "@types/node": "^20.11.24",
        "eslint": "^10.0.3",
        "jest": "^30.0.0",
        "ts-jest": "^29.4.0",
        "typescript": "^5.3.3",
        "typescript-eslint": "^8.57.1"
    }
}
